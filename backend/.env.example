# ═══════════════════════════════════════════════════════
# AEGIS Backend Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Supabase Connection
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Audit Log Encryption Key
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUDIT_ENCRYPTION_KEY=

# JWT Secret for session tokens
JWT_SECRET=change-this-to-a-random-long-string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# AI Model Path
MODEL_PATH=ai/saved_models/lstm_model.pt

# ZK Verification Key Path
ZK_VERIFICATION_KEY_PATH=../zk/verification_key.json
